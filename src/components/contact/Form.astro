---
import { fetchFormData } from "../../lib/getFormData";

const formData = await fetchFormData("240");
---

<div
    class="max-w-[950px] bg-card w-full flex flex-col mt-div_sm_gap lg:mt-div_lg_gap rounded-[30px] mb-[140px] lg:mb-[220px] mx-auto"
>
    <div class="w-full px-6 md:px-8 flex flex-col py-10">
        <div class="mx-auto w-fit flex flex-col justify-center mb-8 md:mb-12">
            <p class="text-primary text-xl text-center font-handwriting italic">
                Contact with us
            </p>
            <h1
                class="font-nunito text-3xl md:text-4xl lg:text-5xl mt-2 text-heading text-center font-bold"
            >
                Feel free to write us <br /> anytime
            </h1>
        </div>

        {
            formData && formData.fields && formData.fields.length > 0 ? (
                <form id="contact-form" class="w-full flex flex-col gap-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6">
                        {formData.fields.map((field: any) => {
                            const isTextarea = field?.type === "textarea";
                            return (
                                <div
                                    class={`flex flex-col gap-2 ${isTextarea ? "md:col-span-2" : ""}`}
                                >
                                    <label class="text-heading text-sm lg:text-[15px] font-semibold">
                                        {field.label}
                                        {field.required && (
                                            <span class="text-red-500 ml-1">
                                                *
                                            </span>
                                        )}
                                    </label>

                                    {isTextarea ? (
                                        <textarea
                                            name={field.name}
                                            required={field.required}
                                            placeholder="Write a Message"
                                            class="rounded-xl border p-4 h-40 border-[#C3E3FA] focus:border-primary outline-none placeholder:text-gray-400 resize-none transition-all"
                                        />
                                    ) : (
                                        <input
                                            type={
                                                field.type === "name"
                                                    ? "text"
                                                    : field.type
                                            }
                                            name={field.name}
                                            required={field.required}
                                            placeholder={`Enter Your ${field.label}`}
                                            class="rounded-xl border p-4 border-[#C3E3FA] focus:border-primary outline-none placeholder:text-gray-400 transition-all"
                                        />
                                    )}
                                </div>
                            );
                        })}
                    </div>

                    {Object.entries(formData?.meta).map(([key, value]) => (
                        <input type="hidden" name={key} value={String(value)} />
                    ))}

                    <div class="flex justify-center mt-4">
                        <button
                            type="submit"
                            class="bg-secondary text-heading py-4 px-12 cursor-pointer font-bold rounded-full hover:shadow-lg transition-all active:scale-95"
                        >
                            Submit Now
                        </button>
                    </div>
                </form>
            ) : (
                <p class="text-center text-red-500 font-semibold mt-6">
                    There is no form data available.
                </p>
            )
        }
    </div>
</div>

<script>
    const form = document.getElementById("contact-form");
    form?.addEventListener("submit", async (e: any) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        try {
            const response = await fetch(
                `${import.meta.env.PUBLIC_WP_API}/wp-admin/admin-ajax.php`,
                {
                    method: "POST",
                    body: formData,
                },
            );
            const result = await response.json();
            if (result.success) {
                alert("Message sent successfully!");
                e.target.reset();
            }
        } catch (error) {
            console.error("Submission error:", error);
        }
    });
</script>
