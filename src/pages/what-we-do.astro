---
import Layout from "../layouts/Layout.astro";

import Banner from "../components/wedo/Banner.astro";
import Driven from "../components/wedo/Driven.astro";
import Services from "../components/wedo/Services.astro";
import Partner from "../components/wedo/Partner.astro";
import Support from "../components/wedo/Support.astro";

import { fetchPageBySlug } from "../lib/getPageData";
import { extractWedoSections } from "../lib/extract/extractWedo";
import { load } from "cheerio";

const page = await fetchPageBySlug("what-we-do");

const $ = load(page.content);
const { bannerContent, drivenContent, serviceContent, supportContent } =
    extractWedoSections($);
    
---

<Layout>
    <!-- overall container -->
    <Banner bannerContent={bannerContent} />
    <main class="w-full">
        <div
            class="w-[92%] sm:w-[90%] md:w-[92%] xl:max-w-[1300px] 2xl:max-w-[1600px] mx-auto"
        >
            <Driven drivenContent={drivenContent} />
            <Services serviceContent={serviceContent} />
            <Partner />
            <Support supportContent={supportContent} />
        </div>
    </main>
</Layout>
