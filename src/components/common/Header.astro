---
import { fetchNavMenu } from "../../lib/getNavMenu";
const navMenu = await fetchNavMenu("primary");
---

<div>
    <div
        class="bg-primary hidden text-white px-16 py-2 md:flex justify-between items-center text-sm font-light"
    >
        <div class="flex items-center space-x-5 mb-2 md:mb-0">
            <a href="#" class="hover:opacity-80"
                ><i class="fab fa-facebook-f text-lg"></i></a
            >
            <a href="#" class="hover:opacity-80"
                ><i class="fab fa-instagram text-lg"></i></a
            >
            <a href="#" class="hover:opacity-80"
                ><i class="fab fa-x-twitter text-lg"></i></a
            >
            <a href="#" class="hover:opacity-80"
                ><i class="fab fa-whatsapp text-lg"></i></a
            >
        </div>

        <div class="flex items-center space-x-6">
            <a
                href="mailto:hello@yourngo.org"
                class="flex items-center space-x-2 hover:underline"
            >
                <i class="far fa-envelope"></i>
                <span>hello@yourngo.org</span>
            </a>
            <div class="flex items-center space-x-2">
                <i class="fas fa-phone-alt"></i>
                <span>+91 2262 222 266</span>
            </div>
        </div>
    </div>

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <nav
        class="bg-white px-4 md:px-16 py-8 w-full flex justify-between items-center"
    >
        <div>
            <a href="/">
                <img
                    src="/src/assets/logo.png"
                    alt="Logo"
                    class="h-8 lg:h-12 w-auto"
                />
            </a>
        </div>
        <div id="menu-btn" class="lg:hidden cursor-pointer">
            <img
                src="/src/assets/hamburger.png"
                alt="Logo"
                class="h-4 w-auto"
            />
        </div>

        <!-- Overlay -->
        <div id="overlay" class="fixed inset-0 bg-black/50 hidden z-40"></div>

        <!-- Side Menu -->
        <div
            id="mobile-menu"
            class="fixed top-0 left-0 h-full w-[280px] bg-white transform -translate-x-full transition-transform duration-300 z-50"
        >
            <div class="flex justify-between items-center p-6 border-b">
                <h2 class="font-bold">Menu</h2>
                <button id="close-menu">✕</button>
            </div>

            <nav class="flex flex-col gap-4 p-6">
                {
                    navMenu.map((item: any) => (
                        <a href={item.path.replace(/\/$/, "")}>{item.label}</a>
                    ))
                }
            </nav>
        </div>

        <div class="hidden lg:flex items-center gap-6">
            <ul class="flex text-sm lg:text-base gap-6">
                {
                    navMenu.map((item: any) => (
                        <li>
                            <a
                                href={item.path.replace(/\/$/, "")}
                                class="cursor-pointer hover:opacity-80 transition-opacity"
                            >
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>

            <div
                class="bg-secondary py-3 px-6 cursor-pointer font-medium rounded-full"
            >
                Donate Now
            </div>
        </div>
    </nav>
</div>

<script>
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("overlay");
    const close = document.getElementById("close-menu");

    function openMenu() {
        menu?.classList.remove("-translate-x-full");
        overlay?.classList.remove("hidden");
    }

    function closeMenu() {
        menu?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
    }

    btn?.addEventListener("click", openMenu);
    close?.addEventListener("click", closeMenu);
    overlay?.addEventListener("click", closeMenu);
</script>
