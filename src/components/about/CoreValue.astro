---
const { coreValueContent } = Astro.props;
const { heading, paragraph, cards } = coreValueContent;
---

<div
    class="max-w-[1120px] 2xl:max-w-[1350px] w-full
         flex flex-col gap-12
         my-div_sm_gap lg:my-div_lg_gap
         mx-auto"
>
    <!-- Heading -->
    <div class="mx-auto w-fit flex flex-col justify-center">
        <p class="text-primary text-xl text-center font-handwriting">
            {paragraph}
        </p>
        <h1
            class="font-nunito text-3xl md:text-5xl
             text-heading font-bold text-center"
        >
            {heading}
        </h1>
    </div>

    <!-- Cards -->
    <div
        class="max-w-[985px] 2xl:max-w-[1050px]
           w-full mx-auto
           grid grid-cols-1 md:grid-cols-2
           gap-6 md:gap-8"
    >
        {
            cards.map((card: any) => (
                <div class="bg-card rounded-[30px] p-6 md:p-8 flex gap-5 items-start">
                    <div
                        class="bg-primary h-16 w-16 min-w-[64px]
                   flex items-center justify-center
                   rounded-full"
                    >
                        <img
                            src="/src/assets/home/hand.png"
                            alt="Compassion"
                            class="w-7 h-7 object-contain"
                        />
                    </div>

                    <div class="flex flex-col gap-2">
                        <h3 class="text-2xl font-nunito font-bold text-heading">
                            {card.heading}
                        </h3>
                        <p class="text-paragraph leading-relaxed">
                            {card.content}
                        </p>
                    </div>
                </div>
            ))
        }
    </div>
    
</div>
