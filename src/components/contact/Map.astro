---
const { mapContent } = Astro.props;
const { image, cards } = mapContent;

const image_icon = {
    Address: "/src/assets/contact/Vector.png",
    Phone: "/src/assets/contact/mobile.png",
    Email: "/src/assets/contact/mail.png",
};
---

<div
    class="w-full relative overflow-visible
         h-[240px] sm:h-[360px] md:h-[460px] lg:h-[560px] 2xl:h-[600px]"
>
    <img src={image} alt="Map" class="w-full h-full object-cover" />

    <div
        class="bg-white rounded-2xl md:rounded-3xl absolute
         top-0 left-1/2
         -translate-x-1/2
         -translate-y-[20%] sm:-translate-y-[30%] lg:-translate-y-1/2
         w-[92%] sm:w-[90%] md:w-[95%]
         max-w-[1070px]
         h-auto lg:h-[185px]
         flex lg:items-center
         px-4 sm:px-6 md:px-10 lg:px-20
         py-6 md:py-8 lg:py-0
         shadow-[0_20px_40px_-12px_rgba(0,0,0,0.25)]"
    >
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3
           w-full gap-6 lg:gap-8"
        >
            {
                cards.map((card) => {
                    const icon = image_icon[card.title];

                    return (
                        <div class="flex items-start gap-3 sm:gap-4">
                            <div
                                class="w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14
                                bg-primary rounded-full
                                flex items-center justify-center shrink-0"
                            >
                                <img
                                    src={icon}
                                    class="w-4 h-4 sm:w-auto sm:h-auto"
                                />
                            </div>

                            <div class="flex flex-col">
                                <span
                                    class="text-sm sm:text-base lg:text-lg
                                    font-bold text-heading"
                                >
                                    {card.title}
                                </span>

                                <span
                                    class="text-xs sm:text-sm md:text-base
                                    text-paragraph leading-tight"
                                >
                                    {card.content}
                                </span>
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>
</div>
