---
const { title, content, image } = Astro.props;
---

<div
    class="bg-card p-6 w-full xl:h-[495px] 2xl:h-[510px] rounded-3xl flex flex-col gap-4"
>
    <img
        src={image}
        alt={title}
        class="w-full h-[200px] xl:h-[240px] 2xl:h-[250px] rounded-lg object-cover"
    />

    <div class="flex flex-col items-start gap-2">
        <h3 class="text-2xl font-nunito font-semibold text-heading">
            {title}
        </h3>
        <p
            class="text-paragraph text-base leading-relaxed"
            set:html={content}
        />
    </div>
    <div class="flex justify-start">
        <button
            class="bg-secondary text-heading flex items-center gap-2 py-3 w-fit
             h-fit px-10 cursor-pointer font-medium rounded-full"
        >
            DownLoad
            <img src="/src/assets/resource/download.png" />
        </button>
    </div>
</div>
