---
import Layout from "../layouts/Layout.astro";

import Banner from "../components/contact/Banner.astro";
import Form from "../components/contact/Form.astro";
import Map from "../components/contact/Map.astro";

import { fetchPageBySlug } from "../lib/getPageData";
import { extractContactSections } from "../lib/extract/extractContact";
import { load } from "cheerio";

const page = await fetchPageBySlug("contact");
const $ = load(page.content);
const { bannerContent, mapContent } = extractContactSections($);
---

<Layout>
    <Banner bannerContent={bannerContent} />
    <!-- overall container -->
    <main class="w-full">
        <div
            class="w-[92%] sm:w-[90%] md:w-[92%] xl:max-w-[1300px] 2xl:max-w-[1600px] mx-auto"
        >
            <Form />
        </div>
    </main>
    <Map mapContent={mapContent} />
</Layout>
